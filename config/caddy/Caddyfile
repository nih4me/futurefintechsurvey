(cors) {
	@origin header Origin {args[0]}
	header @origin Access-Control-Allow-Origin "{args[0]}"
	header @origin Access-Control-Allow-Methods "OPTIONS,HEAD,GET,POST,PUT,PATCH,DELETE"
}


{$CADDY_DOMAIN}:{$CADDY_PORT} {
  log {
    format console
    output file {$LOG_FILE} {
      roll_size 10MB
      roll_keep 10
    }
  }

  @api path /api/* /edit/* /export/* /export /docs/*
  
  handle @api {
    reverse_proxy futurefintechsurvey_api:8000 {
	header_up X-Real-IP {header.X-Forwarded-For}
	header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
      }
  }
  
  import cors ${CORS_ORIGIN}
  root * /static
  file_server 
}

